{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ESNext",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"resolvePackageJsonImports": true,
		"importHelpers": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"strictNullChecks": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"lib": ["DOM", "ESNext"],
		"paths": {
			"#src/*": ["./src/*"]
		}
	},
	"include": ["**/*.ts", "**/*.svelte"]
}
